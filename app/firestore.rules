rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ============================================
     * AUTHENTICATION CHECKS
     * ============================================
     */

    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function: Get current user UID
    function getUserId() {
      return request.auth.uid;
    }

    // Helper function: Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && getUserId() == userId;
    }

    /**
     * ============================================
     * USERS COLLECTION
     * ============================================
     */

    match /users/{userId} {
      // Read: Users can read their own profile and other users' public profiles
      allow read: if isAuthenticated();

      // Create: Users can create their own profile during registration
      allow create: if isOwner(userId) && 
                       request.resource.data.uid == userId &&
                       request.resource.data.email != null &&
                       request.resource.data.username != null;

      // Update: Users can only update their own profile
      allow update: if isOwner(userId) &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.email == resource.data.email;

      // Delete: Users cannot delete profiles (soft delete via admin)
      allow delete: if false;

      /**
       * Follows subcollection
       */
      match /follows/{followId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated();
      }

      /**
       * Followers subcollection
       */
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated();
      }
    }

    /**
     * ============================================
     * POSTS COLLECTION
     * ============================================
     */

    match /posts/{postId} {
      // Read: Any authenticated user can read posts
      allow read: if isAuthenticated();

      // Create: Any authenticated user can create posts
      allow create: if isAuthenticated() &&
                       request.resource.data.authorId == getUserId() &&
                       request.resource.data.text != null &&
                       request.resource.data.text.size() > 0 &&
                       request.resource.data.text.size() <= 5000 &&
                       request.resource.data.createdAt != null;

      // Update: Users can only update their own posts
      allow update: if isOwner(resource.data.authorId) &&
                       resource.data.authorId == request.resource.data.authorId &&
                       (request.resource.data.likes == resource.data.likes ||
                        request.resource.data.comments == resource.data.comments ||
                        request.resource.data.text != resource.data.text);

      // Delete: Users can only delete their own posts
      allow delete: if isOwner(resource.data.authorId);

      /**
       * Comments subcollection
       */
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
                         request.resource.data.authorId == getUserId() &&
                         request.resource.data.text != null &&
                         request.resource.data.text.size() > 0;
        allow update: if isOwner(resource.data.authorId);
        allow delete: if isOwner(resource.data.authorId);
      }

      /**
       * Likes subcollection
       */
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && likeId == getUserId();
        allow delete: if isAuthenticated() && likeId == getUserId();
      }
    }

    /**
     * ============================================
     * COMMENTS COLLECTION (Flat structure)
     * ============================================
     */

    match /comments/{commentId} {
      // Read: Any authenticated user can read comments
      allow read: if isAuthenticated();

      // Create: Any authenticated user can comment
      allow create: if isAuthenticated() &&
                       request.resource.data.authorId == getUserId() &&
                       request.resource.data.postId != null &&
                       request.resource.data.text != null &&
                       request.resource.data.text.size() > 0 &&
                       request.resource.data.text.size() <= 1000;

      // Update: Users can only update their own comments
      allow update: if isOwner(resource.data.authorId) &&
                       resource.data.authorId == request.resource.data.authorId &&
                       resource.data.postId == request.resource.data.postId;

      // Delete: Users can only delete their own comments
      allow delete: if isOwner(resource.data.authorId);
    }

    /**
     * ============================================
     * LIKES COLLECTION (Flat structure)
     * ============================================
     */

    match /likes/{likeId} {
      // Read: Any authenticated user can read likes
      allow read: if isAuthenticated();

      // Create: Users can like posts/comments
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == getUserId() &&
                       (request.resource.data.postId != null ||
                        request.resource.data.commentId != null) &&
                       request.resource.data.type != null;

      // Update: Not allowed
      allow update: if false;

      // Delete: Users can only unlike their own likes
      allow delete: if isAuthenticated() &&
                       resource.data.userId == getUserId();
    }

    /**
     * ============================================
     * FOLLOWS COLLECTION (Flat structure)
     * ============================================
     */

    match /follows/{followId} {
      // Read: Any authenticated user can read follow relationships
      allow read: if isAuthenticated();

      // Create: Users can follow other users
      allow create: if isAuthenticated() &&
                       request.resource.data.followerId == getUserId() &&
                       request.resource.data.followedId != null &&
                       request.resource.data.followerId != request.resource.data.followedId;

      // Update: Not allowed
      allow update: if false;

      // Delete: Users can only unfollow users they are following
      allow delete: if isAuthenticated() &&
                       resource.data.followerId == getUserId();
    }

    /**
     * ============================================
     * DEFAULT DENY ALL
     * ============================================
     */

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
